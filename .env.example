# Copy to `.env` and fill in your keys. `.env` is gitignored — never commit real keys.
# entheai loads this file at startup (via dotenvy); values are read per provider's api_key_env.
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_API_KEY=

# Valyu deep-search MCP: full remote URL including ?valyuApiKey=... (used by [mcp.valyu])
VALYU_MCP_URL=
