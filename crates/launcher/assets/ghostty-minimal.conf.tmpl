# entheai — minimalist branded window (generated by the launcher; do not edit)
macos-titlebar-style = hidden
window-decoration = true
window-padding-x = 14
window-padding-y = 10
window-padding-balance = true
font-family = JetBrainsMono Nerd Font
font-thicken = true
background = #0f0e1d
foreground = #e1cba6
custom-shader = {{SHADER}}
custom-shader-animation = true
minimum-contrast = 1.3
background-opacity = 1.0
confirm-close-surface = false
# Deep scrollback (bytes) — long outputs stay reachable, never clipped by the pane.
scrollback-limit = 104857600
